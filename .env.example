# Required at build time. The slug is hashed into every person_hash and baked
# into the bundle. One slug per deployment.
VITE_DEPARTMENT_SLUG=anesthesia-chuv

# Optional. Defaults to same-origin (empty string). Set this in local dev when
# the backend runs on a different port from the Vite dev server.
VITE_API_BASE_URL=http://localhost:3001
